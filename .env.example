########################
# Postgres
########################
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_PORT=5432

########################
# Server
########################
NODE_ENV=production
SERVER_PORT=5007
CLIENT_URL=http://localhost:8010

# Preferred single connection string for server + migrations
DATABASE_URL=postgres://app_user:app_password@postgres:5432/app_db

# Optional (used if DATABASE_URL is not set)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=app_password

########################
# Client (nginx)
########################
CLIENT_PORT=8010
